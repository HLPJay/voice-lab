{
  "admin": {
    "enabled": true
  },
  "core": {
    "enabled": true,
    "baseUrl": "http://127.0.0.1:8000",
    "timeoutSecs": 20
  },
  "features": {
    "llmCopywritingEnabled": true
  },
  "copywriting": {
    "mode": "llm",
    "provider": "minimax",
    "timeoutSecs": 20,
    "fallbackToTemplate": true,
    "minimax": {
      "baseUrl": "https://api.minimaxi.com",
      "endpointPath": "/v1/chat/completions",
      "model": "<MINIMAX_MODEL_NAME>",
      "apiKey": "<DO_NOT_COMMIT_REAL_KEY>"
    }
  }
}
