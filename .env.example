# Voice Lab Environment Configuration
# Only API keys and infrastructure settings belong here.
# Provider-specific paths/URLs/timeouts are in config/adapters/*.yaml

APP_NAME=Voice Lab
APP_ENV=dev
DATABASE_URL=sqlite:///./voice_lab.db

# Default provider (used by capability_validator for default routing)
VOICE_PROVIDER=minimax

# --- API Keys (secrets only) ---
MINIMAX_API_KEY=replace_me
# MIMO_API_KEY=replace_me

# --- Storage ---
STORAGE_DIR=./storage
DEFAULT_AUDIO_FORMAT=mp3
DEFAULT_SAMPLE_RATE=32000
DEFAULT_BITRATE=128000
DEFAULT_CHANNEL=1

# --- Batch ---
BATCH_MAX_CONCURRENCY=1

# --- Async Task Polling ---
ASYNC_POLL_INTERVAL_SECONDS=5
ASYNC_MAX_WAIT_SECONDS=600

# --- Upload Limits ---
CLONE_AUDIO_MAX_SIZE_MB=20

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=./logs
LOG_RETENTION_DAYS=30

# --- Retry (infrastructure) ---
PROVIDER_RETRY_MAX_ATTEMPTS=3
PROVIDER_RETRY_BACKOFF_BASE=1.0

# --- Mock Fallback ---
MOCK_FALLBACK_PROVIDER=minimax
